# EAS usa este archivo en lugar de .gitignore para decidir que sube al build.
# Mantener en sync con .gitignore + exclusiones extra de cosas que el build no necesita.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local
!.env.example

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

coverage/

# --- Exclusiones especificas de EAS ---
# Skills de agentes IA: no las necesita el build nativo y contienen symlinks
# que rompen la compresion en Windows (EPERM: operation not permitted, symlink).
.claude/
.agents/
