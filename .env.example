# Copia este archivo como .env y rellena los valores.
# Expo CLI carga .env automaticamente en run/start/prebuild.

# ── Mapbox ──────────────────────────────────────────────────────────────────
# Token SECRETO de descarga (account.mapbox.com -> Create token ->
# scope DOWNLOADS:READ). Empieza con sk. Lo usa el build nativo.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=

# Token PUBLICO (Default public token). Empieza con pk. Lo usa el mapa.
MAPBOX_PUBLIC_TOKEN=

# ── Firebase ────────────────────────────────────────────────────────────────
# Project settings -> tus apps -> SDK setup and configuration.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
