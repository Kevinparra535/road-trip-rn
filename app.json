{
  "expo": {
    "name": "Road Trip",
    "slug": "road-trip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "roadtrip",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.roadtrip.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.roadtrip.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-dev-client",
      "@rnmapbox/maps",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Road Trip usa tu ubicacion para mostrar tu posicion en el mapa y planear tus rutas en moto."
        }
      ]
    ]
  }
}
